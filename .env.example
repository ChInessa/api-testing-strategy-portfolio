# Пример переменных окружения для запуска API автотестов

# Базовый URL тестируемого API
BASE_URL=https://api.example.com

# URL сервиса аутентификации
AUTH_URL=https://auth.example.com

# Данные клиента
CLIENT_ID=example-client
CLIENT_SECRET=

# Окружение / realm
REALM=example

# Параметры запуска Newman
COLLECTION_PATH=postman/collections/smoke.postman_collection.json
ENV_PATH=postman/environments/dev.json
FOLDER=
ITERATIONS=1

# Пути для отчётов
REPORTS_DIR=reports
ALLURE_RESULTS_PATH=allure-results
