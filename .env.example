# Пример переменных окружения для запуска API автотестов

# Базовый URL тестируемого API
BASE_URL=https://api.example.com

# URL сервиса аутентификации (например, Keycloak)
AUTH_URL=https://auth.example.com

# Данные клиента (пример)
CLIENT_ID=example-client
CLIENT_SECRET=your-secret

# Realm / окружение
REALM=example

# -----------------------------
# Параметры запуска тестов
# -----------------------------

# Путь к Postman коллекции
COLLECTION_PATH=postman/collections/collection.json

# Путь к environment файлу
ENV_PATH=postman/environments/dev.json

# Путь к globals (если используется)
GLOBAL_PATH=postman/globals.json

# Имя папки (если запуск по folder)
FOLDER=

# Количество итераций
ITERATIONS=1

# -----------------------------
# Пути для отчётов
# -----------------------------

REPORTS_DIR=reports
ALLURE_RESULTS_PATH=allure-results
